{
  "threshold": 100,
  "queries": [
    {
      "$query": [
        { "$eq": { "ArchivalAgencyArchiveUnitIdentifier": "Value1" } }
      ],
      "$action": [
        { "$set": { "Title": "Nouveau titre" } }
      ]
    },
    {
      "$query": [
        { "$eq": { "#id": "some_unit_guid" } }
      ],
      "$action": [
        { "$unset": [ "EndDate" ] },
        { "$set": { "Description": "Description mise à jour" } }
      ]
    }
  ]
}
