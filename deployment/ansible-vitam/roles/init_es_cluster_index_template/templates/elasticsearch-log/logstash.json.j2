{
  "index_patterns": ["logstash-vitam*"],
  "priority": "2",
  "template": {
    "settings" : {
      {% if groups['hosts_elasticsearch_log']|length > 1 %}
      "index.number_of_replicas": {{ kibana.log.metrics.replica }},
      {% else %}
      "index.number_of_replicas": 0,
      {% endif %}
      "index.number_of_shards": {{ kibana.log.metrics.shards }}
    }
  }
}
