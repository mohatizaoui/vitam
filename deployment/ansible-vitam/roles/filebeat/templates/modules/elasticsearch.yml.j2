#jinja2: lstrip_blocks: True

- module: elasticsearch
  server:
    enabled: {{ filebeat.cots.elasticsearch_data.enable_server if inventory_hostname in groups['hosts_elasticsearch_data'] else filebeat.cots.elasticsearch_log.enable_server if inventory_hostname in groups['hosts_elasticsearch_log'] }}
    var.paths:
      {% if inventory_hostname in groups['hosts_elasticsearch_data'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-data/elasticsearch-data.log"
      {% endif %}
      {% if inventory_hostname in groups['hosts_elasticsearch_log'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-log/elasticsearch-log.log"
      {% endif %}
    input:
      fields:
        kind: server
        vitam_component: '{% if inventory_hostname in groups["hosts_elasticsearch_data"] %}elasticsearch-data{% else %}elasticsearch-log{% endif %}'
        source: vitam

  audit:
    enabled: {{ filebeat.cots.elasticsearch_data.enable_audit if inventory_hostname in groups['hosts_elasticsearch_data'] else filebeat.cots.elasticsearch_log.enable_audit if inventory_hostname in groups['hosts_elasticsearch_log'] }}
    var.paths:
      {% if inventory_hostname in groups['hosts_elasticsearch_data'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-data/elasticsearch-data_audit.log"
      {% endif %}
      {% if inventory_hostname in groups['hosts_elasticsearch_log'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-log/elasticsearch-log_audit.log"
      {% endif %}
    input:
      fields:
        kind: audit
        vitam_component: '{% if inventory_hostname in groups["hosts_elasticsearch_data"] %}elasticsearch-data{% else %}elasticsearch-log{% endif %}'
        source: vitam

  slowlog:
    enabled: {{ filebeat.cots.elasticsearch_data.enable_slowlog if inventory_hostname in groups['hosts_elasticsearch_data'] else filebeat.cots.elasticsearch_log.enable_slowlog if inventory_hostname in groups['hosts_elasticsearch_log'] }}
    var.paths:
      {% if inventory_hostname in groups['hosts_elasticsearch_data'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-data/elasticsearch-data_*_slowlog.log"
      {% endif %}
      {% if inventory_hostname in groups['hosts_elasticsearch_log'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-log/elasticsearch-log_*_slowlog.log"
      {% endif %}
    input:
      fields:
        kind: slowlog
        vitam_component: '{% if inventory_hostname in groups["hosts_elasticsearch_data"] %}elasticsearch-data{% else %}elasticsearch-log{% endif %}'
        source: vitam

  deprecation:
    enabled:  {{ filebeat.cots.elasticsearch_data.enable_deprecation if inventory_hostname in groups['hosts_elasticsearch_data'] else filebeat.cots.elasticsearch_log.enable_deprecation if inventory_hostname in groups['hosts_elasticsearch_log'] }}
    var.paths:
      {% if inventory_hostname in groups['hosts_elasticsearch_data'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-data/elasticsearch-data_deprecation.log"
      {% endif %}
      {% if inventory_hostname in groups['hosts_elasticsearch_log'] %}
      - "{{ vitam_defaults.folder.root_path }}/log/elasticsearch-log/elasticsearch-log_deprecation.log"
      {% endif %}
    input:
      fields:
        kind: deprecation
        vitam_component: '{% if inventory_hostname in groups["hosts_elasticsearch_data"] %}elasticsearch-data{% else %}elasticsearch-log{% endif %}'
        source: vitam
