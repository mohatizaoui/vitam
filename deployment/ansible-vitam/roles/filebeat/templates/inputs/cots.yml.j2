#jinja2: lstrip_blocks: True

{% for cots_service in cots_service_list %}
#
# "{{cots_service }}"
#
- type: filestream
  id: "{{ vitam_site_name }}-{{cots_service }}"
  enabled: {{ {'cerebro': filebeat.cots.cerebro.enable_log,
    'grafana': filebeat.cots.grafana.enable_log,
    'prometheus': filebeat.cots.prometheus.enable_log,
    'alertmanager': filebeat.cots.alertmanager.enable_log}[cots_service] | default(true) }}
  paths:
    - "{{ vitam_defaults.folder.root_path }}/log/{{ cots_service }}/{{ cots_service }}*.log"
  fields:
    kind: log
    vitam_component: "{{ cots_service }}"
    source: vitam
{% endfor %}

#
# Consul
#
- type: filestream
  id: "{{ vitam_site_name }}-consul"
  enabled: "{{ filebeat.cots.consul.enable_log }}"
  paths:
    - "{{ vitam_defaults.folder.root_path }}/log/consul/consul*.log"
  fields:
    kind: log
    vitam_component: consul
    source: vitam
  processors:
  - dissect:
      tokenizer: '%{timestamp} [%{loglevel}]  %{logger}: %{message}'
      field: "message"
      target: ""
  - copy_fields:
      fields:
        - from: dissect.loglevel
          to: loglevel
