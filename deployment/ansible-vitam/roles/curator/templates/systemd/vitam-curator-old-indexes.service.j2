[Unit]
Description={{ item[0] }} old indices on elasticsearch-log
Wants=network.target
After=network.target

[Service]
Type=oneshot
ExecStart={{ curator_script_dir }}/run_curator.sh {{ item[0] }}
User=vitam
Group=vitam
StandardOutput=syslog
StandardError=syslog

[Install]
WantedBy=multi-user.target
