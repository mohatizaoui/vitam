[Unit]
Description=Mongod-ui Exporter
Documentation=https://github.com/percona/mongodb_exporter
After=network.target

[Service]
Type=simple
Restart=always
User={{ vitam_defaults.users.vitam }}
Group={{ vitam_defaults.users.group }}
ExecStart={{ vitam_defaults.folder.root_path }}/bin/mongodb_exporter/mongodb_exporter --collect-all \
          --compatible-mode --mongodb.uri=mongodb://{{ mongodb['mongo-vitamui'].admin.user }}:{{ mongodb['mongo-vitamui'].admin.password }}@{{ ip_service }}:{{ mongodb['mongo-vitamui'].mongod_port }} --web.listen-address=:{{ prometheus.mongodb_exporter.port_mongod | default(9217) }}

[Install]
WantedBy=multi-user.target
