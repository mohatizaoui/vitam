[Unit]
Description=The Prometheus monitoring system and time series database.
Documentation=https://prometheus.io
Wants=network-online.target
After=network-online.target

[Service]
ExecStartPre=-/usr/bin/docker pull {{ container_repository.registry_url }}/vitam-external/prom/prometheus:v2.49.1
ExecStartPre=-/usr/bin/docker stop prometheus-server
ExecStartPre=-/usr/bin/docker rm prometheus-server
ExecStart=/usr/bin/docker run --rm --net=host --ulimit memlock=-1:-1 --name prometheus-server \
        -v "/vitam/data/prometheus:/vitam/data/prometheus:rw" \
        -v "/vitam/conf/prometheus:/vitam/conf/prometheus:rw" \
        -v "/vitam/log/prometheus:/vitam/log/prometheus:rw" \
        -v "/vitam/app/prometheus:/vitam/app/prometheus:rw" \
        {{ container_repository.registry_url }}/vitam-external/prom/prometheus:v2.49.1 \
        --web.listen-address={{ prometheus.server.listen_address |default(ip_admin) }}:{{ prometheus.server.port | default(9090) }} \
        --web.external-url=http://{{ prometheus.server.external_url |default(ip_admin) }}:{{ prometheus.server.port | default(9090) }}/prometheus \
        --config.file=/vitam/conf/prometheus/prometheus.yml \
        --storage.tsdb.path=/vitam/data/prometheus \
        --storage.tsdb.retention.time={{ prometheus.server.tsdb_retention_time | default("15d") }} \
        --web.console.libraries=/vitam/app/prometheus/console_libraries \
        --web.console.templates=/vitam/app/prometheus/consoles \
        --storage.tsdb.retention.size={{ prometheus.server.tsdb_retention_size | default("5GB") }}

ExecStop=/usr/bin/docker stop -t 85 prometheus-server
ExecReload=/usr/bin/docker restart -t 85 prometheus-server
TimeoutStartSec=60
TimeoutStopSec=30
StartLimitBurst=6
