# Configuration
@access-contract = ContratTNR
@tenant = 0


### Récupération de la totalité des déails de registres de fonds
POST {{url-access}}/admin-external/v1/accessionregisterdetails
Accept: application/json
Content-Type: application/json
X-Tenant-Id: {{tenant}}
X-Access-Contract-Id: {{access-contract}}

{
  "$query": {},
  "$projection": {},
  "$filter":{},
  "$facets": [
    {
      "$name": "facet_objectSizes",
      "$sum": {
        "$field": "ObjectSize.ingested"
      }
    },
    {
      "$name": "facet_totalUnits",
      "$sum": {
        "$field": "TotalUnits.ingested"
      }
    },
    {
      "$name": "facet_totalObjects",
      "$sum": {
        "$field": "TotalObjects.ingested"
      }
    },
    {
      "$name": "facet_totalObjectsGroups",
      "$sum": {
        "$field": "TotalObjectGroups.ingested"
      }
    }

  ]
}


### Récupération de déails d'un registre de fonds par Oération d'entrée Opi
POST {{url-access}}/admin-external/v1/accessionregisterdetails
Accept: application/json
Content-Type: application/json
X-Tenant-Id: {{tenant}}
X-Access-Contract-Id: {{access-contract}}

{
  "$query":
    {
      "$eq": {
        "Opi": "aeeaaaaaacfohbgoabmfoal2pocc2cyaaaaq"
      }
    },
  "$projection": {},
  "$filter":{}
}
